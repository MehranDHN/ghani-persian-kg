@prefix cvoc: <https://github.com/mehrandhn/ghani-persian-kg/term/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix fhkb: <https://github.com/mehrandhn/genealogy.owl#>  .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix mdhn: <https://github.com/mehrandhn/ghani-persian-kg/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix stamp:   <https://github.com/mehrandhn/ghani-persian-kg/stamp/> .
@prefix logo:   <https://github.com/mehrandhn/ghani-persian-kg/logo/> .
@prefix lethead:   <https://github.com/mehrandhn/ghani-persian-kg/letterhead/> .
@prefix person: <https://github.com/mehrandhn/ghani-persian-kg/person/> .
@prefix place: <https://github.com/mehrandhn/ghani-persian-kg/place/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix so: <https://schema.org/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <https://github.com/mehrandhn/ghani-persian-kg/> .
@prefix doc: <https://github.com/mehrandhn/ghani-persian-kg/document/> .

<https://github.com/mehrandhn/ghani-persian-kg/vocab#> a owl:Ontology ;
    dc:created "2026-04-12"^^xsd:date ;
    dc:creator "Mehran DHN" ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Minimal, extensible ontology for the Ghassem Ghani Collection (MS 235) at Yale. Personalities, places and terms are local controlled vocabularies."@en ;
    rdfs:label "MDHN Ghani Persian Cultural Heritage Ontology"@en .

mdhn:DigitalResource a rdfs:Class ;
    rdfs:comment "A transcribed document from the Ghassem Ghani Collection"@en ;
    rdfs:label "Digital Resource"@en .

mdhn:Personality a rdfs:Class ;
    rdfs:comment "Local scoped controlled vocabulary for persons mentioned in Ghani documents. Can be reconciled with Wikidata later."@en ;
    rdfs:label "Personality"@en ;
    rdfs:subClassOf fhkb:Person .

mdhn:Stamp a rdfs:Class ;
    rdfs:comment "Stamp in documents"@en ;
    rdfs:label "Stamp "@en ;
    rdfs:subClassOf schema:CreativeWork .

mdhn:Logo a rdfs:Class ;
    rdfs:comment "Logo in documents"@en ;
    rdfs:label "Logo "@en . 

mdhn:Letterhead a rdfs:Class ;
    rdfs:comment "Letterhead in documents"@en ;
    rdfs:label "Letterhead"@en .     

mdhn:Place a rdfs:Class ;
    rdfs:comment "Local scoped controlled vocabulary for places. Can be reconciled with TGN later."@en ;
    rdfs:label "Place"@en ;
    rdfs:subClassOf mdhn:GettyTGN .

mdhn:TechnicalTerm a rdfs:Class ;
    rdfs:comment "Local scoped controlled vocabulary for technical/juridical terms. Can be reconciled with AAT later."@en ;
    rdfs:label "Technical Term"@en ;
    rdfs:subClassOf skos:Concept .

mdhn:Category a rdfs:Class ;
    rdfs:comment "Reflects the category of the document"@en ;
    rdfs:label "Category"@en .

mdhn:SubjectSource a owl:Class ;
    rdfs:comment "Root class of all Subject Sources" ;
    rdfs:label "SubjectSource" .

mdhn:AATTerm a owl:Class ;
    rdfs:comment "Root Class for all AAT inherited concepts" ;
    rdfs:label "AATTerm";
     rdfs:subClassOf  mdhn:SubjectSource  .

mdhn:AATSubject a owl:Class ;
    rdfs:comment "Classes choosed as AAT subset for Subjects and it is used to associate AATs as Topical headings to the photographs" ;
    rdfs:label "AATSubject" ;
    rdfs:subClassOf mdhn:AATTerm .     

mdhn:GettyTGN a owl:Class ;
    rdfs:comment "Getty TGN Class for Geographic Places" ;
    rdfs:label "GettyTGN" . 

mdhn:hasTGNPlace a owl:ObjectProperty ;
    rdfs:comment "TGN entry associate the resource to Getty TGN" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasTGNPlace" ;
    rdfs:range mdhn:GettyTGN .

mdhn:usedTGN a owl:ObjectProperty ;
    rdfs:comment "Indicates Resources that used this specified TGN" ;
    rdfs:domain mdhn:GettyTGN ;
    rdfs:label "usedTGN" ;
    rdfs:range mdhn:DigitalResource ;
    owl:inverseOf mdhn:hasTGNPlace .

mdhn:gettyTGNURI a owl:DatatypeProperty ;
    rdfs:comment "The TGN URI is used in Getty AAT" ;
    rdfs:domain mdhn:GettyTGN ;
    rdfs:label "gettyTGNURI" ;
    rdfs:range xsd:string .

mdhn:hasTGNNarrower a owl:ObjectProperty ;
    rdfs:comment "Indicates broader concept of specified TGN" ;
    rdfs:label "hasTGNNarrower" ;
    owl:inverseOf mdhn:hasTGNBroader ;
    so:domainIncludes mdhn:GettyTGN ;
    so:rangeIncludes mdhn:GettyTGN .

mdhn:hasTGNBroader a owl:ObjectProperty ;
    rdfs:comment "Associate a TGN concept to its broader concept" ;
    rdfs:label "hasTGNBroader" ;
    rdfs:domain mdhn:GettyTGN ;
    rdfs:range mdhn:GettyTGN .        

mdhn:ResourceType a owl:Class ;
    rdfs:comment "Classes choosed as a AAT subset and it is used as First Level Classification of all resources." ;
    rdfs:label "Resource Type" ;
    rdfs:subClassOf mdhn:AATTerm . 

mdhn:ofType a owl:ObjectProperty ;
    rdfs:comment "Associates a DigitalResource with its resource type." ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Of Type" ;
    rdfs:range mdhn:ResourceType .

mdhn:hasTypeInstance a owl:ObjectProperty ;
    rdfs:comment "Associates Resource Type to instances." ;
    rdfs:domain mdhn:ResourceType ;
    rdfs:label "has Type Instance" ;
    rdfs:range mdhn:DigitalResource ;
    owl:inverseOf mdhn:ofType .                   

mdhn:documentId a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Ghani ID (e.g. GI 49, G III A 45)"@en ;
    rdfs:range xsd:string .

mdhn:category a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "G-series category (GI, GII, GIX, etc.)"@en ;
    rdfs:range xsd:string .

mdhn:description a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "English description from Yale table"@en ;
    rdfs:range xsd:string .

mdhn:transcription a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Full Persian transcription"@fa ;
    rdfs:range xsd:string .

mdhn:belongsToCategory a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Belongs to category"@en ;
    rdfs:range mdhn:Category .

mdhn:containsDocument a owl:ObjectProperty ;
    rdfs:domain mdhn:Category ;
    rdfs:label "Contains document"@en ;
    rdfs:range mdhn:DigitalResource ;
    owl:inverseOf mdhn:belongsToCategory .   

mdhn:exactlySamePerson a owl:ObjectProperty ;
    rdfs:comment "Links two collection";
    rdfs:domain mdhn:Personality ;
    rdfs:label "exactlySamePerson" ;
    rdfs:range fhkb:Person . 

mdhn:mentionsPersonality a owl:ObjectProperty ;
    rdfs:label "mentionsPersonality"@en;                         
    rdfs:domain mdhn:DigitalResource ;
    rdfs:range mdhn:Personality .

mdhn:collectionDonator a owl:ObjectProperty ;
    rdfs:label "collectionDonator"@en;                         
    rdfs:domain mdhn:Category ;
    rdfs:range mdhn:Personality .    

mdhn:PersonMentionedIn a owl:ObjectProperty;
                 rdfs:label "PersonMentionedIn"@en;
                 rdfs:domain mdhn:Personality;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:mentionsPersonality.

mdhn:mentionsPlace a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Mentions place"@en ;
    rdfs:range mdhn:Place .

mdhn:PlaceMentionedIn a owl:ObjectProperty;
                 rdfs:label "PlaceMentionedIn"@en;
                 rdfs:domain mdhn:Place;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:mentionsPlace.

mdhn:hasTechnicalTerm a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Has technical term"@en ;
    rdfs:range mdhn:TechnicalTerm .

mdhn:termUsedIn a owl:ObjectProperty;
                 rdfs:label "termUsedIn"@en;
                 rdfs:domain mdhn:TechnicalTerm;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:hasTechnicalTerm.

mdhn:hasStamp a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Has stamp"@en ;
    rdfs:range mdhn:Stamp .

mdhn:stampInDocument a owl:ObjectProperty;
                 rdfs:label "stampInDocument"@en;
                 rdfs:domain mdhn:Stamp;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:hasStamp.

mdhn:hasRepresents a owl:ObjectProperty ;
    rdfs:domain mdhn:Stamp ;
    rdfs:label "hasRepresents"@en ;
    rdfs:range mdhn:Personality .

mdhn:hasLogo a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Has Logo"@en ;
    rdfs:range mdhn:Logo .

mdhn:hasLetterhead a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasLetterhead"@en ;
    rdfs:range mdhn:Letterhead .

mdhn:letterheadInDocument a owl:ObjectProperty;
                 rdfs:label "letterheadInDocument"@en;
                 rdfs:domain mdhn:Letterhead;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:hasLetterhead.
                 
mdhn:hasAATBroader a owl:ObjectProperty ;
    rdfs:comment "Associate an AAT concept to its broader concept" ;
    rdfs:label "hasAATBroader" ;
    rdfs:domain mdhn:AATTerm ;
    rdfs:range mdhn:AATTerm .

mdhn:letterheadOwner a owl:ObjectProperty ;
    rdfs:domain mdhn:Letterhead ;
    rdfs:label "letterheadOwner"@en ;
    rdfs:range mdhn:Personality .    

mdhn:croppedStamp a owl:ObjectProperty ;
    rdfs:domain mdhn:Stamp ;
    rdfs:label "Cropped Stamp"@en ;
    rdfs:range xsd:anyURI .  

mdhn:croppedLogo a owl:ObjectProperty ;
    rdfs:domain mdhn:Logo ;
    rdfs:label "Cropped Logo"@en ;
    rdfs:range xsd:anyURI . 

mdhn:croppedLetterhead a owl:ObjectProperty ;
    rdfs:domain mdhn:Leterhead ;
    rdfs:label "Cropped Leterhead"@en ;
    rdfs:range xsd:anyURI .            

mdhn:logoInDocument a owl:ObjectProperty;
                 rdfs:label "logoInDocument"@en;
                 rdfs:domain mdhn:Logo;
                 rdfs:range mdhn:DigitalResource;
                 owl:inverseOf mdhn:hasLogo.    

mdhn:ownerOf a owl:ObjectProperty;
                 rdfs:label "ownerOf"@en;
                 rdfs:domain mdhn:Personality;
                 rdfs:range mdhn:Stamp;
                 owl:inverseOf mdhn:hasRepresents.

mdhn:chronology a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Temporal interval (often AH/AD range)"@en ;
    rdfs:range time:ProperInterval .

mdhn:originalYaleURL a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Original Yale detail page URL"@en ;
    rdfs:range xsd:anyURI  .

mdhn:pdfURL a owl:ObjectProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Local or Internet Archive PDF URL"@en ;
    rdfs:range xsd:anyURI .

mdhn:pdfSha256 a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "SHA-256 hash of the transcription PDF"@en ;
    rdfs:range xsd:string .

mdhn:physicalContainer a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Physical container"@en ;
    rdfs:range xsd:string .  

mdhn:transcriptionPDF a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "transcriptionPDF"@en ;
    rdfs:range xsd:string . 

mdhn:headerNote a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Header note"@en ;
    rdfs:range xsd:string .  

mdhn:footerNote a owl:DatatypeProperty ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "Footer note"@en ;
    rdfs:range xsd:string .               
  

mdhn:iiifManifest a owl:ObjectProperty ;
    rdfs:comment "Placeholder for the IIIF manifest that will be uploaded to Internet Archive later. Use the same item ID as the IA record."@en ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "IIIF Manifest URL"@en ;
    rdfs:range xsd:anyURI . 

mdhn:reconciledWikidata a owl:ObjectProperty ;
    rdfs:domain mdhn:Personality , mdhn:Place , mdhn:TechnicalTerm ;
    rdfs:label "Reconciled with Wikidata (optional)"@en ;
    rdfs:range owl:Thing .

mdhn:reconciledTGN a owl:ObjectProperty ;
    rdfs:domain mdhn:Place ;
    rdfs:label "Reconciled with Getty TGN (optional)"@en .

mdhn:reconciledAAT a owl:ObjectProperty ;
    rdfs:domain mdhn:TechnicalTerm ;
    rdfs:label "Reconciled with Getty AAT (optional)"@en .

doc:GI_049 a mdhn:DigitalResource ;
    mdhn:category "GI" ;
    mdhn:chronology [
        a time:ProperInterval ;
        time:hasBeginning "1830"^^xsd:gYear
    ] ;
    mdhn:description "Sample English summary from Yale table"@en ;
    mdhn:documentId "GI 49" ;
    mdhn:hasTechnicalTerm cvoc:juridical_case ;
    mdhn:iiifManifest <https://archive.org/details/ghani_GI_049/manifest.json> ;
    mdhn:mentionsPersonality person:mirza_aqasi ;
    mdhn:mentionsPlace place:shams_abad ;
    mdhn:originalYaleURL <https://ghani.macmillan.yale.edu/gi-49> ;
    mdhn:pdfSha256 "a1b2c3d4e5f6..." ;
    mdhn:transcription "فدایت شوم جمعی از دوستان ..."@fa .