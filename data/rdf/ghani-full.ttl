    mdhn:transcription """هو
قربان خاکپای همایون مبارکت شوم دستخط مبارک زیارت کردم در باب وجه خزانه انشاءالله مبارک است در باب تشریف بردن خودتان از قراری که مهدی خان میگفت ظاهر پنج ساعت و نیم به شام مانده ساعت است  فدوی هم اگر چه امروز خیلی ناخوش است ولکن قدری بعد از تشریف بردن سرکار به عباس آباد خواهد رفت. زیاده جسارت نورزید. باقی الامر همایون"""@fa .

doc:G_III_A_209 a mdhn:DigitalResource ;
    mdhn:belongsToCategory  mdhn:GIIIA_Correspondences ;
    mdhn:description "Amir Kabir to Naser al-Din Shah: negotiation with the ministers, shooting at the Russian minister’s tent during negotiation"@en ;
    mdhn:documentId "G III A 209" ;
    mdhn:hasTechnicalTerm cvoc:horse_riding,
        cvoc:minister_plenipotentiary,
        cvoc:shooting,
        cvoc:tent,
        cvoc:vazir_mokhtar ;
    mdhn:iiifManifest <https://archive.org/details/MS235_G_III_A_209/manifest.json> ;
    mdhn:mentionsPersonality person:amir_kabir,
        person:naser_al_din_shah ;
    mdhn:mentionsPlace place:ottoman_empire,
        place:russia ;
    mdhn:physicalContainer "Box 1";
    mdhn:transcriptionPDF "g_iii_a_208.pdf";
    rdfs:comment "Amir Kabir to Naser al-Din Shah: negotiation with the ministers, shooting at the Russian minister’s tent during negotiation"@en, 
    "درآمد: از امیر کبیر به ناصرالدین شاه: مذاکره با وزراء مختار، شلیک در چادر وزیر روس در حین مذاکره."@fa ;
    mdhn:originalYaleURL <https://ghani.macmillan.yale.edu/g-iii-209> ;
    mdhn:pdfSha256 "94810d5569f3a3b6b2958bfba3b64bd8684892bf7cc7be46f1dbb0bd1b81c9e2" ;
    mdhn:pdfURL <https://ghani.macmillan.yale.edu/sites/default/files/ms_0235_s03_b001_f0016_d0209.pdf> ;
    mdhn:transcription """هو
قربان خاکپای همایون مبارکت شوم  اولا استفسار از آمدن وزرای مختار فرموده بودید بدیهی است آمدن آنها برای مطلب بیانات بود صحبت طولانی داشتند. مختصرا به حسب حرف حسابی جواب نداشته و ندارند ولکن حالتی دارند که اسم آن را زور عثمانی میگویند از آن راه امریست علی حده و فردا باز چهار ساعت به شام مانده خواهند آمد. البته به عرض شما رسید که در بین صحبت و گفتگو  چند دانه ساچمه به طرف چادر که وزیر مختار روس نشسته بود آمد مذکور شد که تفنگ پادشاهی است. خوش نگذشت و خوش نما نشد . این که میل به سواری دارند با میل خاطر همایون است. زیاده جسارت نورزید باقی الامر همایون
"""@fa .

