    mdhn:belongsToCategory  mdhn:GIIIA_Correspondences ;
    mdhn:description "Amir Kabir to Naser al-Din Shah: visited and wrote to the British and Russian ministers, now they both wish to visit the shah"@en ;
    mdhn:documentId "G III A 210" ;
    mdhn:hasTechnicalTerm cvoc:charg_daffaires,
        cvoc:minister_plenipotentiary,
        cvoc:vazir_mokhtar ;
    mdhn:iiifManifest <https://archive.org/details/MS235_G_III_A_210/manifest.json> ;
    mdhn:mentionsPersonality person:amir_kabir,
        person:mohammad_ali,
